{
  "name": "tencil-cli",
  "version": "0.1.1",
  "description": "CLI for the Tencil universal design translation protocol",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "tencil": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --dts --format esm",
    "test": "vitest --run",
    "dev": "tsup src/cli.ts src/index.ts --dts --format esm --watch"
  },
  "dependencies": {
    "@tencil/core": "workspace:*",
    "@tencil/schema-ui": "workspace:*",
    "@tencil/adapter-penpot-in": "workspace:*",
    "@tencil/adapter-penpot-file-in": "workspace:*",
    "@tencil/adapter-penpot-out": "workspace:*",
    "@tencil/adapter-pencil-out": "workspace:*",
    "@tencil/adapter-pencil-in": "workspace:*",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0"
  }
}
