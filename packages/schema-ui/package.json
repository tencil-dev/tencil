{
  "name": "@tencil/schema-ui",
  "version": "0.1.0",
  "description": "UI/UX domain schema for Tencil — frames, text, shapes, and layout",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@tencil/core": "file:../core"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0"
  }
}
