{
  "name": "@tencil/adapter-penpot-in",
  "version": "0.1.0",
  "description": "Penpot → Tencil adapter for importing Penpot designs",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/types.ts --dts --format esm",
    "test": "vitest --run",
    "dev": "tsup src/index.ts src/types.ts --dts --format esm --watch"
  },
  "dependencies": {
    "@tencil/core": "workspace:*",
    "@tencil/schema-ui": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0"
  }
}
