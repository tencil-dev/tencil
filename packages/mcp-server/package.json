{
  "name": "@tencil/mcp-server",
  "version": "0.1.1",
  "description": "MCP server for Tencil — enables AI agents to work with design documents",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "tencil-mcp": "dist/server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --dts --format esm",
    "test": "vitest --run",
    "dev": "tsup src/index.ts src/server.ts --dts --format esm --watch"
  },
  "dependencies": {
    "@tencil/core": "workspace:*",
    "@tencil/schema-ui": "workspace:*",
    "@tencil/adapter-penpot-in": "workspace:*",
    "@tencil/adapter-pencil-out": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0"
  }
}
