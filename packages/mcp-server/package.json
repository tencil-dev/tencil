{
  "name": "@tencil/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Tencil — enables AI agents to work with design documents",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm",
    "test": "vitest",
    "dev": "tsup src/index.ts --dts --format esm --watch"
  },
  "dependencies": {
    "@tencil/core": "file:../core",
    "@tencil/schema-ui": "file:../schema-ui"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0"
  }
}
